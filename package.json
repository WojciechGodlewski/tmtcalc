{
  "name": "tmtcalc",
  "version": "1.0.0",
  "description": "Backend-only MVP for transport pricing calculator",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:live": "bash scripts/smoke.sh",
    "web:install": "npm --prefix web install",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "build:all": "npm run build && npm run web:build"
  },
  "keywords": [
    "transport",
    "pricing",
    "calculator",
    "backend"
  ],
  "license": "ISC",
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "dotenv": "^16.4.0",
    "fastify": "^4.26.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
